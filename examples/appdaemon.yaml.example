appdaemon:
  # AppDaemon-wide timezone for schedules and timestamps.
  time_zone: UTC
  # Required site latitude in decimal degrees.
  latitude: 0
  # Required site longitude in decimal degrees.
  longitude: 0
  # Required site elevation in meters.
  elevation: 0
  plugins:
    HASS:
      # Use the Home Assistant plugin.
      type: hass
      # Home Assistant base URL reachable from the AppDaemon host/container.
      ha_url: https://home-assistant.local:8123
      # Long-lived access token created from the Home Assistant UI.
      token: YOUR_LONG_LIVED_ACCESS_TOKEN
      # Verify the Home Assistant TLS certificate in the generic example.
      cert_verify: true


# `http`, `admin`, and `api` are omitted by default.
# Enable them only if you want AppDaemon's own web UI or API.
