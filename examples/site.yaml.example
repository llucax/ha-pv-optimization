consumption:
  entity: sensor.total_consumption_power
  # net_entity: sensor.grid_power

battery:
  power_control_entity: number.noah_system_output_power
  actual_power_entity: sensor.noah_output_power
  power_control_label: battery
  # min_output_w: 0
  max_output_w: 800
  power_step_w: 50
  min_change_w: 50
  min_write_interval_s: 60
  max_increase_per_cycle_w: 150
  max_decrease_per_cycle_w: 300
  emergency_max_decrease_per_cycle_w: 500

battery_sensors:
  soc_entity: sensor.noah_soc
  # temperature_entity: sensor.noah_bat0_temperature
  discharge_limit_entity: number.noah_discharge_limit
  # charging_limit_entity: number.noah_charging_limit
  # heating_entity: binary_sensor.noah_heating

inverter:
  power_control_entity: number.ez1_output_power_limit
  actual_power_entity: sensor.ez1_output_power
  power_control_label: inverter
  min_output_w: 30
  max_output_w: 800
  power_step_w: 25
  min_change_w: 25
  min_write_interval_s: 15
  max_increase_per_cycle_w: 300
  max_decrease_per_cycle_w: 300
  emergency_max_decrease_per_cycle_w: 500

control:
  baseline_load_w: 0
  control_interval_s: 5
  consumption_ema_tau_s: 75
  net_ema_tau_s: 45
  deadband_w: 50
  zero_output_threshold_w: 25
  fast_export_threshold_w: -80
  import_correction_gain: 0.35
  export_correction_gain: 1.0
  net_export_negative: true
  command_step_w: 10
  command_lockout_s: 12
  slow_up_deadband_w: 80
  slow_down_deadband_w: -40
  minor_up_event_threshold_w: 150
  major_up_event_threshold_w: 400
  down_event_threshold_w: -150
  minor_up_persistence_s: 3
  major_up_persistence_s: 2
  down_event_persistence_s: 3
  minor_up_multiplier: 0.75
  major_up_multiplier: 0.90
  down_event_multiplier: 0.90
  slow_up_gain: 0.50
  slow_up_max_step_w: 100
  slow_down_guard_w: 20
  slow_down_max_step_w: 300
  visible_oversupply_one_sample_w: -120
  visible_oversupply_two_sample_w: -60
  visible_oversupply_max_cut_w: 500

battery_policy:
  soc_stop_buffer_pct: 0
  soc_full_power_buffer_pct: 0
  soc_min_derate_factor: 1.0

thermal:
  normal_min_soc_pct: 15
  normal_max_soc_pct: 95
  normal_cap_limit_w: 800
  hot_enter_t30_c: 35
  hot_exit_t30_c: 33
  hot_exit_hold_s: 3600
  hot_min_soc_pct: 15
  hot_max_soc_pct: 90
  hot_cap_limit_w: 800
  very_hot_enter_t30_c: 40
  very_hot_enter_t5_c: 45
  very_hot_exit_t30_c: 38
  very_hot_exit_t5_c: 43
  very_hot_exit_hold_s: 3600
  very_hot_min_soc_pct: 20
  very_hot_max_soc_pct: 85
  very_hot_cap_limit_w: 400

maintenance:
  enabled: true
  storage_path: /conf/var/noah_controller.sqlite3
  full_charge_threshold_pct: 99
  full_charge_hold_s: 1800
  max_age_days: 30
  start_min_t30_c: 10
  start_max_t30_c: 35
  maintenance_min_soc_pct: 15
  maintenance_max_soc_pct: 100
  maintenance_path_cap_w: 0

availability:
  warning_grace_s: 3600

logging:
  debug_entity_prefix: sensor.ha_pv_optimization
  # thermal_log: thermal_log
  # thermal_log_level: INFO

devices:
  microwave:
    kind: burst_high_power
    entity_id: sensor.outlet_microwave_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 300
    enter_persistence_s: 2
    exit_persistence_s: 2
    ff_gain: 0.95
    ff_hold_s: 90

  under_cabinet_appliances:
    kind: composite_kitchen_outlet
    entity_id: sensor.outlet_under_cabinet_appliances_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 300
    enter_persistence_s: 2
    exit_persistence_s: 2
    ff_gain: 0.90
    ff_hold_s: 90

  oven:
    kind: cyclic_heater
    entity_id: sensor.outlet_oven_power
    enabled: true
    included_in_total_template: true
    low_threshold_w: 20
    high_threshold_w: 500
    enter_persistence_s: 2
    exit_persistence_s: 2
    ff_gain: 0.90
    ff_hold_s: 120

  dishwasher:
    kind: cyclic_heater
    entity_id: sensor.outlet_dishwasher_power
    enabled: true
    included_in_total_template: true
    low_threshold_w: 20
    high_threshold_w: 500
    enter_persistence_s: 3
    exit_persistence_s: 3
    ff_gain: 0.90
    ff_hold_s: 120

  fridge:
    kind: thermostatic_compressor
    entity_id: sensor.outlet_fridge_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 50
    enter_persistence_s: 5
    exit_persistence_s: 5
    ff_gain: 0.25
    ff_hold_s: 60
    reference_power_w: 100

  freezer:
    kind: thermostatic_compressor
    entity_id: sensor.outlet_freezer_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 50
    enter_persistence_s: 5
    exit_persistence_s: 5
    ff_gain: 0.25
    ff_hold_s: 60
    reference_power_w: 88

  dehumidifier:
    kind: thermostatic_compressor
    entity_id: sensor.outlet_dehumidifier_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 80
    enter_persistence_s: 10
    exit_persistence_s: 10
    ff_gain: 0.20
    ff_hold_s: 90
    reference_power_w: 140

  desk_lena:
    kind: session_baseline
    entity_id: sensor.outlet_desk_lena_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 30
    enter_persistence_s: 15
    exit_persistence_s: 30
    used_for_feed_forward: true
    used_for_baseline_overlay: false
    ff_gain: 0.20
    ff_hold_s: 120
    reference_power_w: 80

  desk_luca:
    kind: session_baseline
    entity_id: sensor.outlet_desk_luca_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 30
    enter_persistence_s: 15
    exit_persistence_s: 30
    used_for_feed_forward: true
    used_for_baseline_overlay: false
    ff_gain: 0.20
    ff_hold_s: 120
    reference_power_w: 80

  media_center:
    kind: session_baseline
    entity_id: sensor.outlet_media_center_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 30
    enter_persistence_s: 15
    exit_persistence_s: 30
    used_for_feed_forward: true
    used_for_baseline_overlay: false
    ff_gain: 0.20
    ff_hold_s: 120
    reference_power_w: 90

  chargers_living:
    kind: session_baseline
    entity_id: sensor.outlet_chargers_living_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 20
    enter_persistence_s: 15
    exit_persistence_s: 30
    used_for_feed_forward: true
    used_for_baseline_overlay: false
    ff_gain: 0.20
    ff_hold_s: 90
    reference_power_w: 60

  living_hall:
    kind: session_baseline
    entity_id: sensor.outlet_living_hall_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 20
    enter_persistence_s: 15
    exit_persistence_s: 30
    used_for_feed_forward: true
    used_for_baseline_overlay: false
    ff_gain: 0.20
    ff_hold_s: 90
    reference_power_w: 100

  schimmeldry:
    kind: session_baseline
    entity_id: sensor.outlet_schimmeldry_power
    enabled: true
    included_in_total_template: true
    high_threshold_w: 50
    enter_persistence_s: 15
    exit_persistence_s: 30
    used_for_feed_forward: true
    used_for_baseline_overlay: false
    ff_gain: 0.15
    ff_hold_s: 120
    reference_power_w: 100

  ap_switch_chargers:
    kind: constant_baseline
    entity_id: sensor.outlet_ap_switch_chargers_power
    enabled: true
    included_in_total_template: true
    used_for_feed_forward: false
    used_for_baseline_overlay: true
    low_threshold_w: 1
    ff_gain: 1.0
    reference_power_w: 10

  fritzbox_printer_rock64:
    kind: constant_baseline
    entity_id: sensor.outlet_fritzbox_printer_rock64_power
    enabled: true
    included_in_total_template: true
    used_for_feed_forward: false
    used_for_baseline_overlay: true
    low_threshold_w: 1
    ff_gain: 1.0
    reference_power_w: 15
