# AppDaemon container image to run.
DOCKER_IMAGE=acockburn/appdaemon:latest
# Host directory containing appdaemon.yaml and apps/.
CONFIG_DIR=/srv/ha-pv-optimization
# Host checkout of this project's source tree.
PROJECT_DIR=/srv/ha-pv-optimization-src
# UID used by the container process.
DOCKER_UID=995
# GID used by the container process.
DOCKER_GID=995
