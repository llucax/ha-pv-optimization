ha_pv_optimization:
  # Bridge module AppDaemon imports from the apps directory.
  module: ha_pv_optimization_app
  # App class instantiated by AppDaemon.
  class: HaPvOptimization

  # Path to the typed site configuration file.
  site_config_path: /conf/apps/site.yaml
  # Compute targets without writing the actuators.
  dry_run: true

  # Delay warnings after an expected-missing window clears.
  # availability_warning_grace_s: 3600
  # Treat low measured output as effectively idle for availability heuristics.
  # availability_idle_output_threshold_w: 20
  # Treat sun below this elevation as low-sun for availability heuristics.
  # availability_low_sun_elevation_deg: 10
