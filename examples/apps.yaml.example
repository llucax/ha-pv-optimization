ha_pv_optimization:
  # Bridge module AppDaemon imports from the apps directory.
  module: ha_pv_optimization_app
  # App class instantiated by AppDaemon.
  class: HaPvOptimization

  # Main house/load power sensor in watts.
  consumption_entity: sensor.house_consumption_power
  # Optional signed grid import/export sensor in watts.
  # Enable this only for a true grid-boundary meter, not for a derived
  # sensor such as house consumption minus inverter output.
  # net_consumption_entity: sensor.grid_power

  # The primary actuator carries the coarse/base target.
  # A writable `number.*` entity can usually infer the service automatically.
  # Battery-style primary control:
  # Writable power-limit entity for the primary actuator.
  battery_power_control_entity: number.battery_output_power_limit
  # Measured real output power for the primary actuator.
  battery_actual_power_entity: sensor.battery_output_power
  # Friendly label used in debug output for the primary actuator.
  battery_power_control_label: battery

  # Optional trim actuator for a faster secondary limit, for example an inverter.
  # inverter_power_control_entity: number.inverter_output_power_limit
  # inverter_actual_power_entity: sensor.inverter_output_power
  # inverter_power_control_label: inverter

  # Optional battery safety inputs.
  # Battery state of charge in percent.
  battery_soc_entity: sensor.battery_soc
  # Battery reserve/discharge floor in percent.
  battery_discharge_limit_entity: number.battery_discharge_limit

  # For non-number domains, set the service explicitly.
  # Home Assistant service used to write the primary actuator.
  # battery_power_control_service: input_number/set_value
  # Service field name carrying the primary numeric target.
  # battery_power_control_value_key: value
  # inverter_power_control_service: input_number/set_value
  # inverter_power_control_value_key: value

  # If the entity exposes numeric min/max/step attributes, the controller can
  # infer them. Otherwise set these explicitly.
  # Minimum allowed primary output target.
  # battery_min_output_w: 0
  # Maximum allowed primary output target.
  # battery_max_output_w: 800
  # Quantization step for primary-actuator writes.
  # battery_power_step_w: 50
  # inverter_min_output_w: 30
  # inverter_max_output_w: 800
  # inverter_power_step_w: 10

  # Constant baseline load offset added to the target calculation.
  baseline_load_w: 0
  # Seconds between controller runs.
  control_interval_s: 30
  # EMA smoothing constant for consumption.
  consumption_ema_tau_s: 75
  # EMA smoothing constant for net import/export when enabled above.
  net_ema_tau_s: 45
  # Ignore small error inside this band.
  deadband_w: 50
  # Snap very small targets down to zero.
  zero_output_threshold_w: 25
  # Strong-export threshold for faster downward correction when enabled.
  fast_export_threshold_w: -80
  # Gain applied when correcting import when enabled.
  import_correction_gain: 0.35
  # Gain applied when correcting export when enabled.
  export_correction_gain: 1.0

  # Minimum target change before a write is sent.
  battery_min_change_w: 50
  # Minimum time between writes.
  battery_min_write_interval_s: 60
  # Maximum upward change per cycle.
  battery_max_increase_per_cycle_w: 150
  # Maximum downward change per cycle.
  battery_max_decrease_per_cycle_w: 300
  # Faster downward change allowed during strong export.
  battery_emergency_max_decrease_per_cycle_w: 500

  # Minimum trim-actuator target change before a write is sent.
  # inverter_min_change_w: 10
  # Minimum time between trim-actuator writes.
  # inverter_min_write_interval_s: 15
  # Maximum trim-actuator upward change per cycle.
  # inverter_max_increase_per_cycle_w: 300
  # Maximum trim-actuator downward change per cycle.
  # inverter_max_decrease_per_cycle_w: 300
  # Faster trim-actuator downward change allowed during strong export.
  # inverter_emergency_max_decrease_per_cycle_w: 500

  # Stop-output buffer above the discharge floor.
  soc_stop_buffer_pct: 3
  # Point above the discharge floor where full power is allowed again.
  soc_full_power_buffer_pct: 10
  # Minimum derate factor inside the SOC ramp region.
  soc_min_derate_factor: 0.25

  # Export is represented as a negative net value when net correction is used.
  net_export_negative: true
  # Prefix for debug/status entities published by the app.
  debug_entity_prefix: sensor.ha_pv_optimization
  # Compute targets without writing the actuator.
  dry_run: true

  # Delay warnings after an expected-missing window clears.
  # availability_warning_grace_s: 3600
  # Treat low measured output as effectively idle for availability heuristics.
  # availability_idle_output_threshold_w: 20
  # Treat sun below this elevation as low-sun for availability heuristics.
  # availability_low_sun_elevation_deg: 10
